    # 创新点一：风险感知 MPC 辅助函数
    # =========================================================================
    def _query_obstacle_distance(self, dis_90, x, y):
        """根据预测点 (x,y) 查询其方位的最近障碍距离 d^obs(theta)。

        与《创新点_风险感知MPC推导.md》第 3 节一致：
            theta_k = atan2(y_k, x_k)
            d^obs_k = d(theta_k)
        车辆坐标系：x 前向、y 左向；激光数组 dis_90 索引 0 对应右侧 -89°，
        索引 ~90 对应正前方，索引 179 对应左侧 +90°。
        """
        if x <= 0.05 and abs(y) < 0.05:
            return float('inf')
        # 角度: 0 deg=+x（前），逆时针为正
        theta = math.atan2(y, x)
        theta_deg = math.degrees(theta)
        idx = int(round(theta_deg + 90.0))
        if idx < 0 or idx >= len(dis_90):
            return float('inf')
        d = float(dis_90[idx])
        if d <= 1e-3:
            return float('inf')
        return d

    # =========================================================================
    # 创新点二：基于时序信息的动态障碍识别
    # =========================================================================
    def _extract_obstacle_summary(self, dis_obs_90, left_obs):
        """单帧障碍几何摘要 z_t = (theta_t, d_t, w_t)。

        与《创新点_时序动态障碍识别推导.md》第 2 节一致：
            c_i = (s_i + e_i)/2,   w_i = e_i - s_i
            i*  = argmin_i d(c_i)
            theta_t = c_i* - 90°,   d_t = d(c_i*),   w_t = w_i*
        """
        if len(left_obs) < 2:
            return {
                'detected': False,
                'distance': float('inf'),
                'center_deg': 0.0,
                'width_deg': 0.0,
            }
        n = len(left_obs) // 2
        best_d = float('inf')
        best_c = 90
        best_w = 0
        for i in range(n):
            s_i = int(left_obs[2 * i])
            e_i = int(left_obs[2 * i + 1])
            c_i = (s_i + e_i) // 2
            if c_i < 0 or c_i >= len(dis_obs_90):
                continue
            d_i = float(dis_obs_90[c_i])
            if d_i <= 1e-3:
                continue
            if d_i < best_d:
                best_d = d_i
                best_c = c_i
                best_w = e_i - s_i
        if best_d == float('inf'):
            return {
                'detected': False,
                'distance': float('inf'),
                'center_deg': 0.0,
                'width_deg': 0.0,
            }
        return {
            'detected': True,
            'distance': float(best_d),
            'center_deg': float(best_c - 90),  # 0=前，正=左，负=右
            'width_deg': float(best_w),
        }

    def _update_obstacle_track(self, summary):
        """维护滑动窗口 H_t 并计算 v^rel_t、omega 均值与 is_dynamic 判别。

        与《创新点_时序动态障碍识别推导.md》第 3-5 节一致：
            v^rel_t  = (d_{t-1} - d_t) / Δt
            \bar{omega}_t = mean_j |theta_j - theta_{j-1}| / Δt
            is_dynamic = (|H_t| ≥ N_min) ∧ (|v^rel|>tau_v ∨ \bar{omega}>tau_omega)
        """
        now = time.monotonic()
        if not summary['detected']:
            self.obs_history.clear()
            out = {
                'detected': False,
                'distance': float('inf'),
                'center_deg': 0.0,
                'width_deg': 0.0,
                'rel_speed': 0.0,
                'omega_deg_s': 0.0,
                'track_count': 0,
                'is_dynamic': False,
            }
            self.last_obs_summary = out
            return out

        sample = (summary['center_deg'], summary['distance'], summary['width_deg'], now)
        self.obs_history.append(sample)
        if len(self.obs_history) > self.obs_history_size:
            self.obs_history.pop(0)

        rel_speed = 0.0
        omega = 0.0
        track_count = len(self.obs_history)
        if track_count >= 2:
            theta_prev, d_prev, _w_prev, t_prev = self.obs_history[-2]
            theta_now, d_now, _w_now, t_now = self.obs_history[-1]
            dt = max(1e-3, t_now - t_prev)
            rel_speed = (d_prev - d_now) / dt
            omega_acc = 0.0
            cnt = 0
            for j in range(1, track_count):
                tj_prev = self.obs_history[j - 1][3]
                tj_now = self.obs_history[j][3]
                dtj = max(1e-3, tj_now - tj_prev)
                dtheta = self.obs_history[j][0] - self.obs_history[j - 1][0]
                omega_acc += abs(dtheta) / dtj
                cnt += 1
            if cnt > 0:
                omega = omega_acc / cnt

        is_dynamic = (
            track_count >= self.obs_min_track_frames
            and (abs(rel_speed) > self.obs_rel_speed_follow_threshold
                 or omega > self.obs_omega_threshold)
        )
        out = {
            'detected': True,
            'distance': summary['distance'],
            'center_deg': summary['center_deg'],
            'width_deg': summary['width_deg'],
            'rel_speed': float(rel_speed),
            'omega_deg_s': float(omega),
            'track_count': int(track_count),
            'is_dynamic': bool(is_dynamic),
        }
        self.last_obs_summary = out
        return out

    def _front_clearance(self, dis_obs_90):
        """前向净空 c_t：取正前方 ±front_clearance_window_deg 范围内的最小距离。"""
        if len(dis_obs_90) < 3:
            return float('inf')
        center = len(dis_obs_90) // 2
        half = max(1, int(self.front_clearance_window_deg))
        lo = max(0, center - half)
        hi = min(len(dis_obs_90), center + half + 1)
        seg = [d for d in dis_obs_90[lo:hi] if d > 1e-3]
        if not seg:
            return float('inf')
        return float(min(seg))

    # =========================================================================
    # 创新点三：自适应行为层 FSM
    # =========================================================================
    def _update_behavior_state(self, obs_summary, front_clear, dis_obs_90):
        """按《创新点_FSM行为决策推导.md》第 4 节执行状态转移。"""
        if not self.fsm_enable:
            self.behavior_state = BEHAVIOR_CRUISE
            return self.behavior_state

        now = time.monotonic()
        dwell = now - self.behavior_state_enter_time
        prev = self.behavior_state

        # 估计左右可通过空间 o_L, o_R（米）：取左/右各 30° 平均距离
        n = len(dis_obs_90)
        if n >= 60:
            left_seg = dis_obs_90[max(0, n // 2 - 60):max(0, n // 2 - 30)]
            right_seg = dis_obs_90[min(n, n // 2 + 30):min(n, n // 2 + 60)]
            left_seg = [d for d in left_seg if d > 1e-3]
            right_seg = [d for d in right_seg if d > 1e-3]
            o_L = float(np.mean(left_seg)) if left_seg else 0.0
            o_R = float(np.mean(right_seg)) if right_seg else 0.0
        else:
            o_L = o_R = 0.0
        side = +1 if o_L >= o_R else -1
        o_side = o_L if side > 0 else o_R

        d_t = obs_summary['distance']
        v_rel = obs_summary['rel_speed']

        new_state = prev

        if prev == BEHAVIOR_CRUISE:
            if obs_summary['detected'] and front_clear < self.fsm_tau_follow:
                new_state = BEHAVIOR_FOLLOW

        elif prev == BEHAVIOR_FOLLOW:
            if (max(o_L, o_R) > self.fsm_tau_prepare
                    and d_t < self.fsm_d_near
                    and v_rel < self.fsm_v_slow
                    and obs_summary['track_count'] >= self.obs_min_track_frames):
                self.behavior_overtake_side = side
                new_state = BEHAVIOR_OVERTAKE_PREPARE
            elif front_clear > self.fsm_tau_return and v_rel < 0:
                new_state = BEHAVIOR_CRUISE

        elif prev == BEHAVIOR_OVERTAKE_PREPARE:
            if o_side > self.fsm_tau_execute and dwell > self.fsm_dwell_prepare_s:
                new_state = BEHAVIOR_OVERTAKE_EXECUTE
            elif front_clear < 0.85 * self.fsm_tau_follow:
                new_state = BEHAVIOR_FOLLOW

        elif prev == BEHAVIOR_OVERTAKE_EXECUTE:
            if dwell > self.fsm_dwell_execute_s and front_clear > self.fsm_tau_return:
                new_state = BEHAVIOR_RETURN_TO_RACELINE

        elif prev == BEHAVIOR_RETURN_TO_RACELINE:
            if dwell > self.fsm_dwell_return_s:
                new_state = BEHAVIOR_CRUISE
                self.behavior_overtake_side = 0

        if new_state != prev:
            self.behavior_state_switch_count += 1
            self.behavior_state = new_state
            self.behavior_state_enter_time = now
            self.get_logger().info(
                f"[FSM] {BEHAVIOR_NAMES[prev]} -> {BEHAVIOR_NAMES[new_state]} "
                f"(c={front_clear:.2f}m d={d_t:.2f}m v_rel={v_rel:.2f}m/s "
                f"o_L={o_L:.2f} o_R={o_R:.2f} side={self.behavior_overtake_side})"
            )
        return self.behavior_state

    def _apply_behavior_heading_bias(self, target_heading):
        """OVERTAKE_PREPARE/EXECUTE 在参考航向上叠加侧向偏置 side*Δψ_bias。"""
        if not self.fsm_enable:
            return target_heading
        if self.behavior_state in (BEHAVIOR_OVERTAKE_PREPARE, BEHAVIOR_OVERTAKE_EXECUTE):
            side = self.behavior_overtake_side if self.behavior_overtake_side != 0 else 1
            return target_heading + side * self.fsm_overtake_heading_bias_rad
        return target_heading

