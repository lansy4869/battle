    # ====================== Raceline 相关函数（已大幅优化弯道速度） ======================
    def _load_raceline(self, csv_path):
        df = pd.read_csv(csv_path, comment='#', header=None)
        raw_array = df.to_numpy(dtype=np.float32)
        self.get_logger().info(f"原始 CSV shape={raw_array.shape}, 列数={raw_array.shape[1]}")
        if raw_array.shape[1] == 4:
            x_vals = raw_array[:, 0]
            y_vals = raw_array[:, 1]
            dx = np.diff(x_vals, append=x_vals[0])
            dy = np.diff(y_vals, append=y_vals[0])
            yaw_vals = np.arctan2(dy, dx)
            dx2 = np.diff(x_vals, append=x_vals[0])
            dy2 = np.diff(y_vals, append=y_vals[0])
            distances = np.sqrt(dx2 + dy2)
            s_vals = np.concatenate([[0.0], np.cumsum(distances[:-1])])
            curvature = np.abs(np.diff(yaw_vals, append=yaw_vals[0])) / (distances + 1e-6)
            # === 关键优化：弯道减速更温和，直道更快 ===
            v_opt = 9.5 / (1.0 + 2.5 * curvature)
            v_opt = np.clip(v_opt, 2.0, 9.5)
            self.raceline_array = np.column_stack([s_vals, x_vals, y_vals, yaw_vals, curvature, v_opt]).astype(np.float32)
            self.get_logger().info(
                f"✅ 已补充缺失列！新 shape={self.raceline_array.shape}\n"
                f" v_opt 范围: [{v_opt.min():.2f}, {v_opt.max():.2f}] m/s（已优化低/高速弯减速）"
            )
        else:
            self.raceline_array = raw_array

        self.raceline_path_msg = Path()
        self.raceline_path_msg.header.frame_id = 'map'
        for i in range(len(self.raceline_array)):
            pose = PoseStamped()
            pose.header.frame_id = 'map'
            x = float(self.raceline_array[i, 1])
            y = float(self.raceline_array[i, 2])
            yaw = float(self.raceline_array[i, 3])
            pose.pose.position.x = x
            pose.pose.position.y = y
            pose.pose.position.z = 0.0
            pose.pose.orientation.x = 0.0
            pose.pose.orientation.y = 0.0
            pose.pose.orientation.z = math.sin(yaw / 2.0)
            pose.pose.orientation.w = math.cos(yaw / 2.0)
            self.raceline_path_msg.poses.append(pose)
        self.get_logger().info(f"✅ 成功加载赛道线！共 {len(self.raceline_array)} 个点")

    def publish_raceline_timer(self):
        if self.raceline_path_msg is not None:
            self.raceline_path_msg.header.stamp = self.get_clock().now().to_msg()
            self.raceline_pub.publish(self.raceline_path_msg)

    def _find_closest_raceline_index(self, current_pose):
        if self.raceline_array is None or current_pose is None:
            return 0
        min_dist = float('inf')
        best_idx = 0
        for i in range(len(self.raceline_array)):
            dx = self.raceline_array[i, 1] - current_pose.pose.position.x
            dy = self.raceline_array[i, 2] - current_pose.pose.position.y
            d = dx * dx + dy * dy
            if d < min_dist:
                min_dist = d
                best_idx = i
        return best_idx

    def _find_index_by_s(self, target_s):
        if self.raceline_array is None:
            return 0
        s_values = self.raceline_array[:, 0]
        total_length = s_values[-1]
        target_s = target_s % total_length
        idx = np.searchsorted(s_values, target_s)
        if idx == len(s_values):
            idx = 0
        return idx

    def _bias_heading_with_laser(self, global_heading, front_state, weight_global=0.85):
        max_dir_index = front_state['max_dir_index']
        global_index = 90 + int(global_heading / math.pi * 180)
        window = 40
        best_idx = max_dir_index
        best_dis = 0
        for i in range(max(0, global_index - window), min(180, global_index + window)):
            dis = front_state['dis_90'][i]
            if dis > best_dis:
                best_dis = dis
                best_idx = i
        fused_index = weight_global * global_index + (1 - weight_global) * best_idx
        return (fused_index - 90) / 180.0 * math.pi

    def _compute_path_curvature(self, points_xy):
        if len(points_xy) < 3:
            return 0.0
        p1 = points_xy[0]
        p2 = points_xy[1]
        p3 = points_xy[2]
        a = math.dist(p1, p2)
        b = math.dist(p2, p3)
        c = math.dist(p3, p1)
        area2 = abs((p2[0] - p1[0]) * (p3[1] - p1[1]) - (p3[0] - p1[0]) * (p2[1] - p1[1]))
        denom = max(a * b * c, 1e-6)
        return float(2.0 * area2 / denom)

    def _safe_speed_from_curvature(self, v_ref, curvature, speed_upper_bound):
        curvature = max(0.0, float(curvature))
        speed_factor = 1.0 / (1.0 + 0.9 * curvature * self.wheelbase)
        v_cmd = float(v_ref) * speed_factor
        v_cmd = max(v_cmd, 1.0)
        v_cmd = float(np.clip(v_cmd, self.alilqr_min_speed, speed_upper_bound))
        return v_cmd

    def _safe_speed_with_front_clearance(self, speed_cmd, front_clearance):
        if front_clearance < 0.8:
            hard_cap = 0.9
        elif front_clearance < 1.2:
            hard_cap = 1.2
        elif front_clearance < 1.8:
            hard_cap = 1.8
        else:
            hard_cap = self.final_speed_cap
        return float(min(speed_cmd, hard_cap))

    def _compute_location_confidence(self):
        if not self.confidence_enable or not self.have_odom:
            return 1.0 if self.have_odom else 0.0
        now_t = time.monotonic()
        if self.last_odom_rx_time <= 0.0:
            return 0.0
        age = now_t - self.last_odom_rx_time
        if age <= self.loc_conf_timeout_s:
            return 1.0
        if age >= self.loc_conf_fade_s:
            return 0.0
        conf = 1.0 - (age - self.loc_conf_timeout_s) / max(1e-3, self.loc_conf_fade_s - self.loc_conf_timeout_s)
        return float(np.clip(conf, 0.0, 1.0))

    def _compute_perception_confidence(self, front_state):
        obs = front_state['obs_summary']
        front_clearance = float(front_state['front_clearance'])
        clear_norm = float(np.clip(front_clearance / max(1e-3, self.risk_clearance_threshold_m * 1.6), 0.0, 1.0))
        track_norm = float(np.clip(obs['track_count'] / max(1.0, float(self.obs_min_track_frames + 2)), 0.0, 1.0))
        dynamic_penalty = 0.15 if obs['is_dynamic'] else 0.0
        detect_penalty = 0.0 if obs['detected'] else 0.1
        conf = 0.45 * clear_norm + 0.45 * track_norm + 0.1
        conf = conf - dynamic_penalty - detect_penalty
        return float(np.clip(conf, 0.0, 1.0))

    def _compute_control_confidence(self, front_state):
        loc_conf = self._compute_location_confidence()
        percep_conf = self._compute_perception_confidence(front_state)
        control_conf = min(loc_conf, percep_conf)
        self.last_loc_confidence = float(loc_conf)
        self.last_perception_confidence = float(percep_conf)
        self.last_control_confidence = float(control_conf)
        return float(control_conf)

    def _compute_ttc(self, front_state):
        obs = front_state['obs_summary']
        if not obs['detected']:
            return float('inf')
        front_dist = max(0.01, float(obs['distance']))
        closing_speed = max(0.0, float(obs['rel_speed']))
        if closing_speed <= 1e-3:
            return float('inf')
        return float(front_dist / closing_speed)

    def _compute_risk_speed_scale(self, front_state, base_speed):
        if not self.risk_longitudinal_enable:
            self.last_ttc_s = float('inf')
            self.last_risk_speed_scale = 1.0
            return 1.0
        ttc = self._compute_ttc(front_state)
        self.last_ttc_s = float(ttc)
        clearance = float(front_state['front_clearance'])
        ttc_scale = 1.0
        if math.isfinite(ttc):
            if ttc <= self.risk_ttc_hard_s:
                ttc_scale = 0.25
            elif ttc < self.risk_ttc_threshold_s:
                ttc_scale = (ttc - self.risk_ttc_hard_s) / max(1e-3, self.risk_ttc_threshold_s - self.risk_ttc_hard_s)
                ttc_scale = 0.25 + 0.75 * ttc_scale
        clear_scale = float(np.clip(clearance / max(1e-3, self.risk_clearance_threshold_m), 0.3, 1.0))
        scale = min(ttc_scale, clear_scale)
        floor = float(self.risk_speed_floor_ratio)
        scale = float(np.clip(scale, floor, 1.0))
        if base_speed < 0.8:
            scale = min(1.0, scale + 0.15)
        self.last_risk_speed_scale = float(scale)
        return float(scale)

    def _adaptive_lqr_scales(self, speed_upper_bound, curvature, front_state, control_conf):
        if not self.alilqr_adaptive_enable:
            self.last_adaptive_q_scale = 1.0
            self.last_adaptive_r_scale = 1.0
            return 1.0, 1.0
        speed_ratio = float(np.clip(abs(self.odom_speed) / max(0.5, speed_upper_bound), 0.0, 1.6))
        curve_ratio = float(np.clip(abs(curvature) / 0.25, 0.0, 2.0))
        clearance_ratio = float(np.clip(self.risk_clearance_threshold_m / max(0.2, front_state['front_clearance']), 0.0, 2.0))
        conf_drop = 1.0 - float(np.clip(control_conf, 0.0, 1.0))
        q_scale = 1.0 + self.alilqr_speed_sched_gain * speed_ratio + self.alilqr_curve_sched_gain * curve_ratio + self.alilqr_clearance_sched_gain * clearance_ratio
        q_scale *= 1.0 + self.alilqr_conf_sched_gain * conf_drop * 0.5
        q_scale = float(np.clip(q_scale, self.alilqr_min_weight_scale, self.alilqr_max_weight_scale))
        r_scale = 1.0 + 0.65 * self.alilqr_speed_sched_gain * speed_ratio + 0.9 * self.alilqr_curve_sched_gain * curve_ratio + 0.8 * self.alilqr_clearance_sched_gain * clearance_ratio
        r_scale *= 1.0 + (self.conf_r_scale_max - 1.0) * conf_drop
        r_scale = float(np.clip(r_scale, self.alilqr_min_weight_scale, self.alilqr_max_weight_scale * self.conf_r_scale_max))
        self.last_adaptive_q_scale = q_scale
        self.last_adaptive_r_scale = r_scale
        return q_scale, r_scale

    def _solve_dare(self, A, B, Q, R, max_iter=120, eps=1e-6):
        P = Q.copy()
        for _ in range(max_iter):
            BT_P = B.T @ P
            S = R + BT_P @ B
            try:
                S_inv = np.linalg.inv(S)
            except np.linalg.LinAlgError:
                S_inv = np.linalg.pinv(S)
            P_next = A.T @ P @ A - A.T @ P @ B @ S_inv @ BT_P @ A + Q
            if np.max(np.abs(P_next - P)) < eps:
                P = P_next
                break
            P = P_next
        BT_P = B.T @ P
        S = R + BT_P @ B
        try:
            K = np.linalg.inv(S) @ BT_P @ A
        except np.linalg.LinAlgError:
            K = np.linalg.pinv(S) @ BT_P @ A
        return K

    def build_local_ref(self, front_state, speed_upper_bound, current_pose=None, heading_blend_override=None):
        horizon = self.alilqr_horizon
        dt = self.alilqr_dt
        points_xy = []
        if self.raceline_array is None or current_pose is None:
            target_heading = (float(front_state['max_dir_index']) - 90.0) / 180.0 * math.pi
            target_heading = float(np.clip(target_heading, -0.9, 0.9))
            v_des = float(np.clip(2.2 * self.speed_rate, self.alilqr_min_speed, speed_upper_bound))
            lookahead = float(np.clip(
                self.alilqr_min_lookahead + self.alilqr_lookahead_speed_gain * max(abs(self.odom_speed), v_des),
                self.alilqr_min_lookahead,
                self.alilqr_max_lookahead,
            ))
            for k in range(horizon):
                s = lookahead + (k + 1) * dt * max(v_des, 0.3)
                points_xy.append((s * math.cos(target_heading), s * math.sin(target_heading)))
            target_x = points_xy[0][0]
            target_y = points_xy[0][1]
            target_idx = -1
        else:
            closest_idx = self._find_closest_raceline_index(current_pose)
            lookahead = float(np.clip(
                self.alilqr_min_lookahead + self.alilqr_lookahead_speed_gain * max(abs(self.odom_speed), 1.0),
                self.alilqr_min_lookahead,
                self.alilqr_max_lookahead,
            ))
            lookahead_s = self.raceline_array[closest_idx, 0] + lookahead
            target_idx = self._find_index_by_s(lookahead_s)
            target_x = float(self.raceline_array[target_idx, 1])
            target_y = float(self.raceline_array[target_idx, 2])
            dx = target_x - current_pose.pose.position.x
            dy = target_y - current_pose.pose.position.y
            target_heading = math.atan2(dy, dx)
            v_des = float(self.raceline_array[target_idx, 5])
            v_des = float(np.clip(v_des, self.alilqr_min_speed, speed_upper_bound))
            heading_blend = self.alilqr_heading_blend if heading_blend_override is None else heading_blend_override
            target_heading = self._bias_heading_with_laser(target_heading, front_state, weight_global=heading_blend)
            for k in range(horizon):
                s_k = lookahead_s + (k + 1) * dt * max(v_des, 0.3)
                idx_k = self._find_index_by_s(s_k)
                points_xy.append((float(self.raceline_array[idx_k, 1]), float(self.raceline_array[idx_k, 2])))

        target_heading = self._apply_behavior_heading_bias(target_heading)

        x_ref = np.zeros(horizon)
        y_ref = np.zeros(horizon)
        yaw_ref = np.zeros(horizon)
        v_ref = np.zeros(horizon)
        for k in range(horizon):
            x_ref[k] = points_xy[k][0]
            y_ref[k] = points_xy[k][1]
            if k == 0:
                dxk = points_xy[k][0]
                dyk = points_xy[k][1]
            else:
                dxk = points_xy[k][0] - points_xy[k - 1][0]
                dyk = points_xy[k][1] - points_xy[k - 1][1]
            yaw_ref[k] = math.atan2(dyk, dxk) if (abs(dxk) + abs(dyk)) > 1e-6 else target_heading
            v_ref[k] = v_des

        curvature = self._compute_path_curvature(points_xy[:3])
        if target_idx >= 0 and self.raceline_array is not None and self.raceline_array.shape[1] >= 5:
            curvature = max(curvature, float(abs(self.raceline_array[target_idx, 4])))
        return {
            'x': x_ref,
            'y': y_ref,
            'yaw': yaw_ref,
            'v': v_ref,
            'target_heading': float(target_heading),
            'target_x': float(target_x),
            'target_y': float(target_y),
            'curvature': float(curvature),
        }

    def solve_alilqr(self, ref, speed_upper_bound, front_state, control_confidence, current_pose=None):
        start_t = time.monotonic()
        if not self.have_odom or current_pose is None:
            elapsed_ms = (time.monotonic() - start_t) * 1000.0
            return False, 0.0, self.alilqr_min_speed, 0.0, 0.0, 0.0, elapsed_ms, 'no_odom'

        dx = ref['target_x'] - current_pose.pose.position.x
        dy = ref['target_y'] - current_pose.pose.position.y
        yaw_ref = float(ref['target_heading'])
        lat_err = -math.sin(yaw_ref) * dx + math.cos(yaw_ref) * dy
        heading_err = self._normalize_angle(yaw_ref - self.odom_yaw)
        v_state = float(np.clip(abs(self.odom_speed), self.alilqr_min_speed, speed_upper_bound))
        dt = self.alilqr_dt
        e_dot = (lat_err - self.prev_lateral_error) / max(dt, 1e-3)
        psi_dot = (heading_err - self.prev_heading_error) / max(dt, 1e-3)

        A = np.array([
            [1.0, dt, 0.0, 0.0],
            [0.0, 0.0, v_state, 0.0],
            [0.0, 0.0, 1.0, dt],
            [0.0, 0.0, 0.0, 0.0],
        ], dtype=np.float64)
        B = np.array([
            [0.0],
            [v_state / self.wheelbase],
            [0.0],
            [v_state / self.wheelbase],
        ], dtype=np.float64)
        curvature = float(max(0.0, ref.get('curvature', 0.0)))
        q_scale, r_scale = self._adaptive_lqr_scales(
            speed_upper_bound=speed_upper_bound,
            curvature=curvature,
            front_state=front_state,
            control_conf=control_confidence,
        )
        q_conf_scale = 1.0 - (1.0 - self.conf_q_scale_min) * (1.0 - float(np.clip(control_confidence, 0.0, 1.0)))
        Q = np.diag([
            self.alilqr_q_e * q_scale * q_conf_scale,
            self.alilqr_q_edot * q_scale * q_conf_scale,
            self.alilqr_q_psi * q_scale * q_conf_scale,
            self.alilqr_q_psidot * q_scale * q_conf_scale,
        ]).astype(np.float64)
        R = np.array([[self.alilqr_r_delta * r_scale]], dtype=np.float64)
        K = self._solve_dare(A, B, Q, R)
        x_state = np.array([[lat_err], [e_dot], [heading_err], [psi_dot]], dtype=np.float64)
        delta_fb = float(-(K @ x_state)[0, 0])

        delta_ff = float(self.alilqr_ff_gain * math.atan(self.wheelbase * curvature))
        delta_raw = delta_fb + delta_ff
        delta_cmd = (1.0 - self.alilqr_steer_smooth) * delta_raw + self.alilqr_steer_smooth * self.last_alilqr_steer
        delta_cmd = float(np.clip(delta_cmd, -math.pi / 4, math.pi / 4))

        v_ref_curve = self._safe_speed_from_curvature(ref['v'][0], curvature, speed_upper_bound)
        risk_speed_scale = self._compute_risk_speed_scale(front_state, v_ref_curve)
        conf_speed_scale = self.conf_speed_scale_floor + (1.0 - self.conf_speed_scale_floor) * float(np.clip(control_confidence, 0.0, 1.0))
        v_ref_lqr = max(self.alilqr_min_speed, v_ref_curve * risk_speed_scale * conf_speed_scale)
        speed_err = float(v_ref_curve - v_state)
        A_v = np.array([[1.0]], dtype=np.float64)
        B_v = np.array([[self.alilqr_dt]], dtype=np.float64)
        q_v_scale = 1.0 + 0.8 * q_scale
        r_v_scale = 1.0 + 0.6 * r_scale
        Q_v = np.array([[self.alilqr_q_v * q_v_scale]], dtype=np.float64)
        R_v = np.array([[self.alilqr_r_accel * r_v_scale]], dtype=np.float64)
        K_v = self._solve_dare(A_v, B_v, Q_v, R_v)
        speed_err = float(v_ref_lqr - v_state)
        accel_raw = float((K_v @ np.array([[speed_err]], dtype=np.float64))[0, 0])
        accel_cmd = (1.0 - self.alilqr_accel_smooth) * accel_raw + self.alilqr_accel_smooth * self.last_alilqr_accel
        accel_cmd = float(np.clip(accel_cmd, self.alilqr_max_decel, self.alilqr_max_accel))
        v_cmd = float(np.clip(v_state + accel_cmd * self.alilqr_dt, self.alilqr_min_speed, speed_upper_bound))
        elapsed_ms = (time.monotonic() - start_t) * 1000.0

        self.prev_lateral_error = float(lat_err)
        self.prev_heading_error = float(heading_err)
        self.last_lateral_error = float(lat_err)
        self.last_heading_error = float(heading_err)
        self.last_speed_error = float(speed_err)
        self.last_alilqr_accel = float(accel_cmd)
        return True, delta_cmd, v_cmd, float(accel_cmd), float(lat_err), float(heading_err), elapsed_ms, 'ok'

    def control_select_and_publish(self, data, current_frame, front_state, current_pose=None):
        drive_msg = AckermannDriveStamped()
        drive_msg.header = data.header
        mode = CONTROL_MODE_ALILQR
        steer_cmd = self.last_alilqr_steer
        speed_cmd = max(self.alilqr_min_speed, min(self.last_alilqr_speed, self.final_speed_cap))
        alilqr_ok = False
        solve_ms = 0.0
        self.control_cycle_count += 1
        if self.fsm_enable:
            self._update_behavior_state(front_state)
        else:
            self._set_behavior_state(BEHAVIOR_CRUISE)
            self.behavior_overtake_side = 0
            self.Follow = False
            self.chaoche = False
        speed_upper_bound = self.alilqr_max_speed
        if self.behavior_state == BEHAVIOR_FOLLOW:
            speed_upper_bound = min(speed_upper_bound, self.follow_speed_cap)
        elif self.behavior_state in (BEHAVIOR_OVERTAKE_PREPARE, BEHAVIOR_OVERTAKE_EXECUTE):
            speed_upper_bound = min(speed_upper_bound, self.chaoche_speed_cap)
        speed_upper_bound = float(min(speed_upper_bound, self.final_speed_cap))
        self.current_speed_upper_bound = speed_upper_bound

        control_confidence = self._compute_control_confidence(front_state)
        heading_blend = self.alilqr_heading_blend
        if self.confidence_enable:
            heading_blend = self.conf_heading_blend_floor + (self.alilqr_heading_blend - self.conf_heading_blend_floor) * control_confidence
            heading_blend = float(np.clip(heading_blend, self.conf_heading_blend_floor, 1.0))

        self.alilqr_attempt_count += 1
        ref = self.build_local_ref(front_state, speed_upper_bound, current_pose, heading_blend_override=heading_blend)
        alilqr_ok, alilqr_steer, alilqr_speed, alilqr_accel, _, _, solve_ms, reason = self.solve_alilqr(
            ref, speed_upper_bound, front_state, control_confidence, current_pose
        )
        if alilqr_ok:
            steer_cmd = alilqr_steer
            speed_cmd = alilqr_speed
            self.last_alilqr_accel = float(alilqr_accel)
            self.alilqr_success_count += 1
            self.sum_solve_time_ms += float(solve_ms)
            self.max_solve_time_ms = max(self.max_solve_time_ms, float(solve_ms))
        else:
            self.last_solver_reason = reason
            self.last_alilqr_accel = 0.0
            self.last_speed_error = 0.0

        self.last_solve_time_ms = float(solve_ms)
        if mode != self.last_control_mode:
            self.mode_switch_count += 1
        self.last_alilqr_steer = steer_cmd
        self.last_alilqr_speed = speed_cmd
        speed_cmd = float(min(speed_cmd, speed_upper_bound))
        speed_cmd = self._safe_speed_with_front_clearance(speed_cmd, front_state['front_clearance'])
        self.last_risk_min_margin = -1.0

        if self.behavior_state == BEHAVIOR_FOLLOW:
            print('\033[35m跟随！！22222！！跟随！！2222！！\033[0m')
            speed_cmd = float(min(self.follow_speed_cap, speed_cmd))
        elif self.behavior_state in (BEHAVIOR_OVERTAKE_PREPARE, BEHAVIOR_OVERTAKE_EXECUTE):
            print('''\033[31m _____ _____
\033[32m / ____| / ____|
\033[33m | (___ _ _ _ __ ___ _ __ | | __
\033[34m \___ \| | | | '_ \ / _ \ '__| | | |_ |
\033[35m ____) | |_| | |_) | / | | || |
\033[36m |/ \,_| ./ \___|_| \_____|
\033[37m | |
\033[35m |_| \033[5m超车模式启动！！！\033[0m''')
        elif self.behavior_state == BEHAVIOR_RETURN_TO_RACELINE:
            print('\033[36m回归主线中...\033[0m')

        drive_msg.drive.steering_angle = float(np.clip(steer_cmd, -math.pi / 4, math.pi / 4))
        drive_msg.drive.speed = float(np.clip(speed_cmd, 0.0, self.final_speed_cap))
        drive_msg.drive.acceleration = float(self.last_alilqr_accel)
        self.last_cmd_steer = float(drive_msg.drive.steering_angle)
        self.last_cmd_speed = float(drive_msg.drive.speed)
        if drive_msg.drive.steering_angle > 0:
            print('转向左转%f度' % (abs(drive_msg.drive.steering_angle * 180 / math.pi)))
        else:
            print('转向右转%f度' % (abs(drive_msg.drive.steering_angle * 180 / math.pi)))

        self.publish_arrow_marker(front_state['max_dir_index'], current_frame)
        self.last_max_dir_index = front_state['max_dir_index']

        alilqr_msg = AckermannDriveStamped()
        alilqr_msg.header = data.header
        alilqr_msg.drive.steering_angle = float(np.clip(self.last_alilqr_steer, -math.pi / 4, math.pi / 4))
        alilqr_msg.drive.speed = float(np.clip(self.last_alilqr_speed, 0.0, self.alilqr_max_speed))
        alilqr_msg.drive.acceleration = float(self.last_alilqr_accel)
        self.alilqr_pub.publish(alilqr_msg)
        mode_msg = UInt8()
        mode_msg.data = int(mode)
        self.mode_pub.publish(mode_msg)
        behavior_msg = UInt8()
        behavior_msg.data = int(self.behavior_state)
        self.behavior_pub.publish(behavior_msg)
        ok_msg = Bool()
        ok_msg.data = bool(alilqr_ok)
        self.alilqr_ok_pub.publish(ok_msg)
        self.last_control_mode = mode
        self.pre_safety_pub.publish(drive_msg)
        self.drive_pub.publish(drive_msg)

    def middle_line_callback(self, data):
        clean_ranges = np.nan_to_num(np.array(data.ranges), posinf=0.0, neginf=0.0)
        data.ranges = clean_ranges.tolist()
        current_frame = data.header.frame_id if data.header.frame_id else 'laser'
        front_state = self.frontend_scan_process(data)

        current_pose = None
        if self.have_odom:
            current_pose = PoseStamped()
            current_pose.pose.position.x = self.odom_position_x
            current_pose.pose.position.y = self.odom_position_y
            current_pose.pose.orientation.w = math.cos(self.odom_yaw / 2.0)
            current_pose.pose.orientation.z = math.sin(self.odom_yaw / 2.0)
            current_pose.header.frame_id = 'map'

        self.control_select_and_publish(data, current_frame, front_state, current_pose)


def main(args=None):
    rclpy.init(args=args)
    battle_node = BattleVehicleNode()
    try:
        rclpy.spin(battle_node)
    except KeyboardInterrupt:
        pass
    finally:
        battle_node.destroy_node()
        rclpy.shutdown()


if __name__ == '__main__':
    main()
